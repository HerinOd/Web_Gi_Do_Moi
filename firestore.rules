rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Hàm kiểm tra Đăng nhập
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Hàm lấy role của người đang đăng nhập (Truy xuất chéo sang bảng users)
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // 3. Hàm kiểm tra quyền Admin
    function isAdmin() {
      return isSignedIn() && myRole() == 'admin';
    }

    // 4. Hàm kiểm tra quyền Đăng Truyện (Admin HOẶC Dịch Giả)
    function canUpload() {
      return isSignedIn() && (myRole() == 'admin' || myRole() == 'translator');
    }

    // =====================================
    // BẢNG USERS
    // =====================================
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // BẢO MẬT:
      // - Admin được phép sửa hồ sơ người khác (dùng để PHONG/GỠ quyền Dịch Giả).
      // - Người dùng tự sửa thông tin cá nhân của mình, NHƯNG NGHIÊM CẤM tự sửa role của chính mình.
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == userId
                        && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == resource.data.role));

      allow delete: if isAdmin();
    }

    // =====================================
    // BẢNG STORIES
    // =====================================
    match /stories/{storyId} {
      allow read: if true;
      // Chỉ Admin hoặc Dịch Giả mới được đăng truyện
      allow create: if canUpload();
      
      // Admin hoặc Chủ truyện được phép XÓA
      allow delete: if isSignedIn() && (resource.data.uploaderId == request.auth.uid || isAdmin());
      
      allow update: if 
        // Admin hoặc Chủ truyện được phép SỬA toàn bộ
        (isSignedIn() && (resource.data.uploaderId == request.auth.uid || isAdmin()))
        || 
        // Khách ẩn danh chỉ được phép tăng views
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']))
        || 
        // User đăng nhập được phép tăng likes
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount', 'views']));
    }

    // =====================================
    // BẢNG CHAPTERS
    // =====================================
    match /chapters/{chapterId} {
      allow read: if true;
      // Chỉ Admin hoặc Dịch Giả mới được đăng chương
      allow create: if canUpload();
      allow update, delete: if isSignedIn() &&
        (get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.uploaderId == request.auth.uid || isAdmin());
    }

    // =====================================
    // BẢNG COMMENTS
    // =====================================
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      
      // Admin hoặc Chủ comment được phép XÓA
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if
        // Admin hoặc Chủ comment được phép SỬA nội dung
        (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()))
        ||
        // Mọi user đăng nhập được quyền thả tim
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']));
    }

    // =====================================
    // CONFIG (Thông báo, Danh sách Tags)
    // =====================================
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}